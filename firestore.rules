rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function hasRole(role) { return isSignedIn() && getUserData().role == role; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Users ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && incoming().role in ['student', 'teacher', 'admin', 'registrar', 'finance'];
      allow update: if isSignedIn() && isOwner(userId) && incoming().role == existing().role;
    }

    // --- Students ---
    match /students/{studentId} {
      allow read: if isSignedIn() && (isOwner(existing().userId) || hasRole('admin') || hasRole('registrar') || hasRole('teacher'));
      allow write: if hasRole('admin') || hasRole('registrar');
    }

    // --- Teachers ---
    match /teachers/{teacherId} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin');
    }

    // --- Courses ---
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin') || hasRole('registrar');
    }

    // --- Enrollments ---
    match /enrollments/{enrollmentId} {
      allow read: if isSignedIn() && (isOwner(existing().studentId) || hasRole('registrar') || hasRole('admin'));
      allow create: if hasRole('student') && isOwner(incoming().studentId);
      allow update: if hasRole('registrar') || hasRole('admin');
    }

    // --- Grades ---
    match /grades/{gradeId} {
      allow read: if isSignedIn() && (isOwner(existing().studentId) || hasRole('teacher') || hasRole('admin') || hasRole('registrar'));
      allow write: if hasRole('teacher') || hasRole('admin');
    }

    // --- Payments ---
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (isOwner(existing().studentId) || hasRole('finance') || hasRole('admin'));
      allow write: if hasRole('finance') || hasRole('admin');
    }

    // --- Evaluations ---
    match /evaluations/{evaluationId} {
      allow read: if hasRole('admin') || (hasRole('teacher') && isOwner(existing().teacherId));
      allow create: if hasRole('student') && isOwner(incoming().studentId);
    }
  }
}
